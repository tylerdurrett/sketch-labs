{
  "permissions": {
    "allow": [
      "Bash(gh issue close:*)",
      "Bash(gh issue edit:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pr-merge-gate.sh" }
        ]
      }
    ]
  }
}
