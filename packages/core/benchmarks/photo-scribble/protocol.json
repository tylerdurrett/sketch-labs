          "space": "target-border-box",
          "xFraction": 0.5,
          "yFraction": 0.5
        },
        "action": "single primary-pointer click",
        "start": "page performance.now mark immediately before Puppeteer mouseDown at the resolved coordinate",
        "end": "first requestAnimationFrame after the same button aria-label becomes Hide inspector"
      },
      {
        "probeId": "toggle-shading-disclosure",
        "target": "the summary element whose direct span text is exactly Shading",
        "coordinate": {
          "space": "target-border-box",
          "xFraction": 0.5,
          "yFraction": 0.5
        },
        "action": "single primary-pointer click",
        "start": "page performance.now mark immediately before Puppeteer mouseDown at the resolved coordinate",
        "end": "first requestAnimationFrame after parent details.open changes from its pre-click value"
      }
    ],
    "cancellation": {
      "target": "input#control-chaos",
      "coordinate": {
        "space": "target-border-box",
        "xFraction": 0.5,
        "yFraction": 0.5
      },
      "action": "select the complete value, type a value exactly 0.01 below the scenario chaos value, and press Enter; restore the fixed scenario before the next measured job",
      "start": "page performance.now immediately before the first input event that begins the superseding edit",
      "end": "coordinator clock when the superseded job resolves cancelled and its worker termination has been invoked"
    },
    "terminalToDisplay": {
      "start": "coordinator receipt time for terminal progress",
      "end": "first requestAnimationFrame after current result diagnostics and canvas identity both match the completed worker identity"
    },
    "toneSampling": {
      "samplingRule": "Sample the production Tone Field and Shading Mask directly at each exact Composition Frame point after Image Asset resolution and contain-fit. Record unrounded IEEE-754 values; screenshots are secondary evidence.",
      "pixelCenterRule": "For source pixel (x,y), frame point is (fitLeft + (x + 0.5) * fitScale, fitTop + (y + 0.5) * fitScale).",
      "gammaSweep": {
        "toneGammaValues": [
          0,
          0.5,
          1
        ],
        "fixedToneContrast": 0.5
      },
      "contrastSweep": {
