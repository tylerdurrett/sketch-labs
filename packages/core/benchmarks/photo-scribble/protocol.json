  "measurement": {
    "heartbeat": {
      "start": "performance.now immediately before the coordinator posts the compute request to the worker",
      "samples": "coordinator receipt time for every accepted progress message, including terminal progress",
      "end": "coordinator receipt time for terminal progress or worker success/failure when terminal progress is absent",
      "gaps": "request-to-first, every consecutive sample pair, and last-sample-to-end; the maximum is compared with maxProgressHeartbeatGapMs"
    },
    "interactionProbeEnvironment": "Run all probes while the same fine-scenario worker job is active, after the first non-terminal heartbeat and before terminal progress.",
    "interactionProbes": [
      {
        "probeId": "hide-inspector",
        "target": "button[aria-label='Hide inspector']",
        "coordinate": {
          "space": "target-border-box",
          "xFraction": 0.5,
          "yFraction": 0.5
        },
        "action": "single primary-pointer click",
        "start": "page performance.now mark immediately before Puppeteer mouseDown at the resolved coordinate",
        "end": "first requestAnimationFrame after the same button aria-label becomes Show inspector"
      },
      {
        "probeId": "show-inspector",
