{
  "name": "@harness/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "benchmark:grass-hills-density": "vitest run --config vitest.grass-hills-density-benchmark.config.ts",
    "benchmark:hidden-line": "vitest run --config vitest.hidden-line-benchmark.config.ts",
    "benchmark:leaf-field": "vitest run --config vitest.leaf-field-benchmark.config.ts",
    "benchmark:photo-scribble": "vitest run --config vitest.photo-scribble-benchmark.config.ts",
    "benchmark:stippling-relaxation": "node benchmarks/stippling-relaxation/cli.js run --mode=smoke",
    "benchmark:stippling-relaxation:zero-baseline": "vitest run --config vitest.stippling-zero-baseline-benchmark.config.ts",
    "benchmark:stippling-relaxation:full": "node benchmarks/stippling-relaxation/cli.js run --mode=full --confirm-full",
    "benchmark:stippling-relaxation:aggregate": "node benchmarks/stippling-relaxation/cli.js aggregate",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "alea": "^1.0.1",
    "delaunator": "^5.1.0",
    "lineclip": "^2.0.0",
    "robust-predicates": "^3.0.3",
    "simplex-noise": "^4.0.3"
  },
  "devDependencies": {
    "@types/lineclip": "^2.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
